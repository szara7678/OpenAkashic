# OpenAkashic — Closed Web (Knowledge Vault) Environment
# Copy to .env and fill in your own values.

# Where your markdown vault lives on the host; mounted into the container.
CLOSED_AKASHIC_PATH=/vault/closed

# Subdirectories that agents (including the MCP tools) may write to.
CLOSED_AKASHIC_WRITABLE_ROOTS=doc,personal_vault,assets

# Public base URL where your Closed Akashic web UI is served from.
# When running locally, you can use http://localhost:8001.
CLOSED_AKASHIC_PUBLIC_BASE_URL=https://knowledge.example.com

# Comma-separated list of browser origins allowed to call the API.
CLOSED_AKASHIC_CORS_ORIGINS=https://knowledge.example.com,http://localhost:3000,http://localhost:5173

# Bootstrap admin token. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Rotate regularly; it grants admin access to agent tools and the MCP server.
CLOSED_AKASHIC_BEARER_TOKEN=replace-me-with-a-64-char-hex-string

# System admin account seeded on first boot. Pick your own handle.
CLOSED_AKASHIC_ADMIN_USERNAME=admin
CLOSED_AKASHIC_ADMIN_NICKNAME=admin
CLOSED_AKASHIC_DEFAULT_NOTE_OWNER=admin

# Sagwan (the "librarian" agent) model provider.
# Supported: claude-cli | openai-compatible | codex-cli
CLOSED_AKASHIC_LIBRARIAN_PROVIDER=claude-cli

# Optional: URL of your OpenAkashic Core API (if running both services).
# OPENAKASHIC_CORE_API_BASE_URL=https://api.example.com
# OPENAKASHIC_CORE_API_KEY=
